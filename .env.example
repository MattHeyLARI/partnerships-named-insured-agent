# partnerships-named-insured-agent — environment variables
# Copy to .env.local for local development

ANTHROPIC_API_KEY=                        # Anthropic API key — required for named insured research

PARTNERSHIPS_SOV_APP_URL=                 # Deployed URL of partnerships-sov-app (no trailing slash)
PARTNERSHIPS_NAICS_APP_URL=               # Deployed URL of partnerships-naics-app (no trailing slash)
PARTNERSHIPS_BENCHMARK_APP_URL=           # Deployed URL of partnerships-benchmark-app (no trailing slash)
PARTNERSHIPS_LOSS_RESEARCH_URL=           # Deployed URL of partnerships-loss-research (no trailing slash)
